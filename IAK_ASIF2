            f.write("$scan\n")
            f.write(f"  angle: {a1}, {a2}, {a3}, {angle_start}, {angle_end}, {n_steps}\n")
            f.write("$end\n")

        self._pes_log(
            f"[Angle Scan] xTB angle {a1}-{a2}-{a3}: "
            f"{angle_start}° → {angle_end}° in {n_steps} steps …"
        )
        cmd = f'"{xtb_exe}" {mol_file} --opt --input scan_angle.inp'
