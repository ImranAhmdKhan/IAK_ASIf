    def _launch_metad_fes(self):
        import threading
        v = self._vars_fes
        hills = v["hills_file"].get().strip()
        if not hills or not os.path.isfile(hills):
            return messagebox.showerror("MetaD FES", "Select a HILLS file.")
        out = v["fes_out"].get().strip() or os.path.dirname(hills)
