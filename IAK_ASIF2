        frame = tk.LabelFrame(parent, text=" HIGH-LEVEL JOB PROGRESS, PERCENT COMPLETE, AND ETA ", fg=_C["accent"], bg=_C["panel"], font=("Segoe UI", 10, "bold"), padx=10, pady=8)
